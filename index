<script>
  let gender = 'male';
  let goal = 'maintain';

  function setGender(g, el) {
    gender = g;
    document.querySelectorAll('.gender-btn').forEach(b => b.classList.remove('active'));
    el.classList.add('active');
  }

  function setGoal(g, el) {
    goal = g;
    document.querySelectorAll('.goal-btn').forEach(b => {
      b.classList.remove('active-lose','active-maintain','active-gain');
    });
    el.classList.add('active-' + g);
  }

  // Default: maintain active
  document.querySelectorAll('.goal-btn')[1].classList.add('active-maintain');

  function calculate() {
    const age    = parseFloat(document.getElementById('age').value);
    const weight = parseFloat(document.getElementById('weight').value);
    const height = parseFloat(document.getElementById('height').value);
    const actMul = parseFloat(document.getElementById('activity').value);

    if (!age || !weight || !height || isNaN(age) || isNaN(weight) || isNaN(height)) {
      alert('Please fill all fields first!');
      return;
    }

    // Mifflin-St Jeor
    let bmr;
    if (gender === 'male') {
      bmr = 10 * weight + 6.25 * height - 5 * age + 5;
    } else {
      bmr = 10 * weight + 6.25 * height - 5 * age - 161;
    }

    const tdee = Math.round(bmr * actMul);
    const lose  = Math.round(tdee - 500);
    const gain  = Math.round(tdee + 300);

    let mainCal, desc;
    if (goal === 'lose') {
      mainCal = lose;
      desc = `Eating <strong>${lose} kcal/day</strong> puts you in a ~500 kcal deficit. Expect to lose ~0.5kg/week sustainably.`;
    } else if (goal === 'gain') {
      mainCal = gain;
      desc = `Eating <strong>${gain} kcal/day</strong> gives you a lean ~300 kcal surplus — ideal for muscle gain with minimal fat.`;
    } else {
      mainCal = tdee;
      desc = `Your TDEE is <strong>${tdee} kcal/day</strong>. Eating at this number keeps your weight stable.`;
    }

    // Macros based on goal
    let protein, carbs, fats;
    if (goal === 'lose') {
      protein = Math.round(weight * 2.2);
      fats    = Math.round(mainCal * 0.25 / 9);
      carbs   = Math.round((mainCal - protein * 4 - fats * 9) / 4);
    } else if (goal === 'gain') {
      protein = Math.round(weight * 2.0);
      fats    = Math.round(mainCal * 0.25 / 9);
      carbs   = Math.round((mainCal - protein * 4 - fats * 9) / 4);
    } else {
      protein = Math.round(weight * 1.8);
      fats    = Math.round(mainCal * 0.28 / 9);
      carbs   = Math.round((mainCal - protein * 4 - fats * 9) / 4);
    }

    const totalMacroG = protein + carbs + fats;

    // Update DOM
    document.getElementById('mainCalories').textContent = mainCal.toLocaleString();
    document.getElementById('resultDesc').innerHTML = desc;
    document.getElementById('calsLose').textContent    = lose.toLocaleString();
    document.getElementById('calsMaintain').textContent = tdee.toLocaleString();
    document.getElementById('calsGain').textContent    = gain.toLocaleString();

    document.getElementById('macroProtein').textContent = protein + 'g';
    document.getElementById('macroCarbs').textContent   = carbs + 'g';
    document.getElementById('macroFats').textContent    = fats + 'g';

    // Bars (animate after small delay)
    setTimeout(() => {
      document.getElementById('barProtein').style.width = Math.round(protein/totalMacroG*100) + '%';
      document.getElementById('barCarbs').style.width   = Math.round(carbs/totalMacroG*100) + '%';
      document.getElementById('barFats').style.width    = Math.round(fats/totalMacroG*100) + '%';
    }, 100);

    // Show results
    document.getElementById('formSection').style.display = 'none';
    const res = document.getElementById('results');
    res.style.display = 'block';
    res.scrollIntoView({ behavior: 'smooth', block: 'start' });
  }

  function reset() {
    document.getElementById('formSection').style.display = 'block';
    document.getElementById('results').style.display = 'none';
    window.scrollTo({ top: 0, behavior: 'smooth' });
  }
</script>
